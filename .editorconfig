root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{md,yml,yaml,json,toml}]
indent_size = 2

[*.{rs}]
indent_size = 4
max_line_length = 100

[*.py]
indent_size = 4
max_line_length = 100

[*.ps1]
indent_size = 4
end_of_line = crlf

[Makefile]
indent_style = tab
