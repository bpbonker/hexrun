* text=auto eol=lf

# Source files always LF
*.rs        text eol=lf
*.toml      text eol=lf
*.py        text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.cfg       text eol=lf
*.sh        text eol=lf

# PowerShell scripts use CRLF (Windows convention)
*.ps1       text eol=crlf
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Binaries
*.onnx      binary
*.gguf      binary
*.bin       binary
*.png       binary
*.jpg       binary
*.ico       binary
*.dll       binary
*.exe       binary
